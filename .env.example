# ============================================
# DocMind Environment Configuration Template
# ============================================
# IMPORTANT: Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control
# ============================================

# ============================================
# PostgreSQL Database Configuration
# ============================================
POSTGRES_USER=docmind
POSTGRES_PASSWORD=changeme_secure_password
POSTGRES_DB=docmind
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ============================================
# MinIO Object Storage Configuration
# ============================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_secure_password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=docmind-documents
MINIO_USE_SSL=false

# ============================================
# Qdrant Vector Database Configuration
# ============================================
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URL=http://${QDRANT_HOST}:${QDRANT_PORT}

# ============================================
# Ollama LLM Configuration
# ============================================
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_URL=http://${OLLAMA_HOST}:${OLLAMA_PORT}
OLLAMA_MODEL=llama2

# ============================================
# Go Service Configuration
# ============================================
GO_SERVICE_PORT=8080
GO_SERVICE_GRPC_PORT=9090
GO_SERVICE_HOST=go-service

# JWT Authentication (CRITICAL - Use a strong random secret in production)
JWT_SECRET=changeme_use_strong_random_secret_min_32_chars
JWT_EXPIRATION_HOURS=24

# ============================================
# Python RAG Service Configuration
# ============================================
PYTHON_SERVICE_PORT=8000
PYTHON_SERVICE_GRPC_PORT=50051
PYTHON_SERVICE_HOST=python-rag-service

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ============================================
# gRPC Configuration
# ============================================
GRPC_PYTHON_SERVICE_URL=${PYTHON_SERVICE_HOST}:${PYTHON_SERVICE_GRPC_PORT}
GRPC_TIMEOUT_SECONDS=60

# ============================================
# Application Configuration
# ============================================
# Environment: development, staging, production
APP_ENV=development

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# File upload limits
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_EXTENSIONS=pdf,txt,docx,md

# Pagination defaults
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
